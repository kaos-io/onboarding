# Generated by the KAOS dashboard. Save as terraform.tfvars (gitignored) in this directory.
# Each org gets a unique WIF pool: {org_name}-kaosid.

# Required
org_name             = "acme"               # <=19 chars, [a-z][a-z0-9-]*[a-z0-9]
gcp_project_id       = "acme-prod"
gcp_project_number   = "123456789012"
broker_app_client_id = "376257051585676814"

# Optional (defaults shown)
zitadel_issuer       = "https://access.platform.kaos-labs.org"

# Optional — dedicated GitHub App org only. Leave both empty for shared-app orgs.
# Pass the private key on the CLI so it stays out of this file:
#   terraform apply -var-file=terraform.tfvars -var="github_app_private_key=$(cat ./app.pem)"
github_app_id          = ""
# github_app_private_key supplied via -var at apply time, NOT here.

# Optional — Meluxina HPC integration. Disabled by default. When enabled, point
# meluxina_ssh_key_path at the signed private key file bound to your Meluxina account;
# its raw bytes are pushed to the deterministic 'meluxina-ssh-key' GSM secret.
enable_meluxina_ssh_key = false
# meluxina_ssh_key_path = "/absolute/path/to/meluxina_private_key"
